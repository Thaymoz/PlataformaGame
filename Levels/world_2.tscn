[sub_resource type="GDScript" id="GDScript_lkj02"]
script/source = "extends Node2D

@onready var area_sign: Area2D = $area_sign
@onready var texture: Sprite2D = $texture

const lines : Array[String] = [
	\"Olá\",
	\"berinjela\",
	\"manga\",
	\"torrada torrada torrada torrada\",
	\"leite condensado com mel e castanha de caju empilhado com papa ganhuche\",
]

func _unhandled_input(event: InputEvent) -> void:
	if area_sign.get_overlapping_bodies().size()>0:
		texture.show()
		if event.is_action_pressed(\"interact\") && !DialogManager.is_message_actived:
			texture.hide()
			DialogManager.start_message(global_position, lines)
		else:
			texture.hide()
"

